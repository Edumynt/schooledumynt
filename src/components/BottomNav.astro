---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const navItems = [
  {
    label: 'Home',
    href: '/',
    exact: true,
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    iconFilled: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M12.707 2.293a1 1 0 0 0-1.414 0l-9 9A1 1 0 0 0 3 13h1v8a1 1 0 0 0 1 1h5v-6h4v6h5a1 1 0 0 0 1-1v-8h1a1 1 0 0 0 .707-1.707l-9-9z"/></svg>`,
  },
  {
    label: 'Grammar',
    href: '/grammar',
    exact: false,
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="15" y2="13"/></svg>`,
    iconFilled: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M6.5 2A3.5 3.5 0 0 0 3 5.5v13A3.5 3.5 0 0 0 6.5 22H20a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1H6.5zM8 8h8a1 1 0 0 1 0 2H8a1 1 0 0 1 0-2zm0 4h8a1 1 0 0 1 0 2H8a1 1 0 0 1 0-2z"/></svg>`,
  },
];

function isActive(href: string, exact: boolean) {
  if (exact) return currentPath === href;
  return currentPath.startsWith(href);
}
---

<nav class="bottom-nav" role="navigation" aria-label="Main navigation">
  <div class="bottom-nav__inner">
    {navItems.map((item) => {
      const active = isActive(item.href, item.exact);
      return (
        <a
          href={item.href}
          class={`bottom-nav__item ${active ? 'bottom-nav__item--active' : ''}`}
          aria-current={active ? 'page' : undefined}
        >
          <span class="bottom-nav__icon">
            <Fragment set:html={active ? item.iconFilled : item.icon} />
          </span>
          <span class="bottom-nav__label">{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>

<style>
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--bottom-nav-height);
    background: var(--color-bg-nav);
    box-shadow: var(--shadow-nav);
    z-index: var(--z-header);
    transition: background var(--transition-base);
    /* Safe area for notched phones */
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  .bottom-nav__inner {
    display: flex;
    align-items: center;
    height: 100%;
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .bottom-nav__item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    height: 100%;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    -webkit-tap-highlight-color: transparent;
    position: relative;
  }

  .bottom-nav__item:hover {
    color: var(--color-text-secondary);
  }

  .bottom-nav__item--active {
    color: var(--color-primary);
  }

  .bottom-nav__item--active::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 32px;
    height: 3px;
    background: var(--color-primary);
    border-radius: 0 0 var(--radius-full) var(--radius-full);
  }

  .bottom-nav__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 28px;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }

  .bottom-nav__item--active .bottom-nav__icon {
    background: var(--color-primary-subtle);
  }

  .bottom-nav__label {
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    line-height: var(--leading-none);
    letter-spacing: var(--tracking-wide);
  }
</style>
